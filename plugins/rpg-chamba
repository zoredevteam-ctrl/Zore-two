let handler = async (m, { conn, usedPrefix, command }) => {
    // Definimos la base de datos del usuario (usando el sistema nativo del bot)
    let user = global.db.data.users[m.sender]
    if (!user) return // Seguridad

    // Si quieres usar una moneda específica, si no, usamos 'money' o 'limit'
    const moneda = 'monedas' 
    const ganancia = 180
    const tiempoEspera = 900000 // 15 minutos

    // Reacción inicial
    await m.react('🍬')

    // Verificar Cooldown
    if (new Date - user.lastchamba < tiempoEspera) {
        let tiempo = Math.ceil((user.lastchamba + tiempoEspera - new Date()) / 60000)
        return m.reply(`💔 *¡Todavía no, darling!* 🌸\n\nYa hiciste tu quest RPG. Vuelve en *${tiempo} minutos* para seguir divirtiéndonos juntos~`)
    }

    // Entregar recompensa
    user.money = (user.money || 0) + ganancia
    user.lastchamba = new Date * 1
    
    const trollText = `💗 *¡QUEST RPG-CHAMBA COMPLETADA!* 🌸\n\n` +
                     `Entraste a la mazmorra a matar slimes... pero terminaste chupándosela al Slime Rey durante 3 horas seguidas y te dio *${ganancia} ${moneda}* como recompensa 😂\n\n` +
                     `¡Zero Two aprueba esta quest troll! 💕\n` +
                     `*Saldo actual:* ${user.money} ${moneda}`

    await m.reply(trollText)
}

handler.help = ['chamba']
handler.tags = ['rpg']
handler.command = ['chamba', 'work'] 
handler.register = true // Para que funcione si el usuario está registrado

export default handler
